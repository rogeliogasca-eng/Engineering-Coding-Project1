 #Function 3: Get digits from the user 
def get_numbers():
    try:
        num1 = float(input("Enter the first number:"))
        num2 = float(input("Enter the second number:"))
        return num1, num2
    except ValueError:
        print("Error: Please enter valid numbers user!")
        return None, None


 #Function 4: Do the calculation
def calculate(num1, num2):
    try:
        operation = input("Choose operation (+, -, *, /):").strip()

        if operation == "+":
            result = num1 + num2

        elif operation == "-":
            result = num1 - num2

        elif operation == "*":
            result = num1 * num2

        elif operation == "/":
            if num2 == 0:
                raise ZeroDivisionError
                result = num1 / num2

        else:
            raise TypeError

        print("Result:", result)

    except ZeroDivisionError:
        print("Error: You cannot devide by zero")

    except ValueError as ve:
        print("Error:", ve)

    except TypeError:
        print("Error: invalid operation selected.")

    except Exception:
        print("Error:  Something went wrong buddy.")



#Main Program

user_name = get_user_name() 

num1, num2 = get_numbers()
if num1 is not None and num2 is not None:
    calculate(num1, num2)

print(f"\nThank you for being creative with the calculator, {user_name}!")

